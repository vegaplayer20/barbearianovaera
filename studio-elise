<style>
  :root{
    --bg-0:#0c0a08;
    --bg-1:#161310;
    --bg-2:#1f1b16;
    --gold:#c79a5f;
    --gold-soft:rgba(199,154,95,0.16);
    --text-1:#f3ede4;
    --text-2:#a89e91;
    --line:rgba(243,237,228,0.1);
  }
  *{margin:0;padding:0;box-sizing:border-box;}
  html{scroll-behavior:smooth;}
  body{
    background:var(--bg-0);
    color:var(--text-1);
    font-family:'Jost',sans-serif;
    font-weight:300;
    overflow-x:hidden;
  }
  h1,h2,h3,.serif{font-family:'Cormorant Garamond',serif;font-weight:500;}
  em{font-style:italic;color:var(--gold);}
  a{text-decoration:none;color:inherit;}
  .eyebrow{
    font-size:11px;letter-spacing:0.22em;text-transform:uppercase;
    color:var(--gold);font-weight:500;
  }
  .wrap{max-width:1200px;margin:0 auto;padding:0 40px;}
  @media(max-width:768px){.wrap{padding:0 22px;}}

  /* NAVBAR */
  nav{
    position:fixed;top:0;left:0;right:0;z-index:100;
    padding:26px 0;transition:all .4s ease;
    background:transparent;
  }
  nav.scrolled{
    background:rgba(12,10,8,0.85);
    backdrop-filter:blur(14px);
    padding:16px 0;
    border-bottom:1px solid var(--line);
  }
  .nav-inner{display:flex;align-items:center;justify-content:space-between;}
  .logo{font-size:24px;letter-spacing:0.02em;}
  .logo-sub{display:block;font-family:'Jost';font-size:9px;letter-spacing:0.3em;color:var(--text-2);font-weight:400;margin-top:2px;}
  .nav-links{display:flex;gap:38px;list-style:none;}
  .nav-links a{
    font-size:12px;letter-spacing:0.12em;text-transform:uppercase;
    position:relative;padding-bottom:4px;color:var(--text-2);
    transition:color .3s;
  }
  .nav-links a::after{
    content:'';position:absolute;bottom:0;left:0;width:0;height:1px;
    background:var(--gold);transition:width .3s ease;
  }
  .nav-links a:hover, .nav-links a.active{color:var(--text-1);}
  .nav-links a:hover::after, .nav-links a.active::after{width:100%;}
  .btn{
    display:inline-flex;align-items:center;gap:8px;
    padding:13px 26px;font-size:12px;letter-spacing:0.1em;text-transform:uppercase;
    border-radius:3px;transition:all .3s ease;cursor:pointer;border:1px solid transparent;
  }
  .btn-gold{background:var(--gold);color:var(--bg-0);font-weight:500;}
  .btn-gold:hover{background:#dba968;transform:translateY(-1px);}
  .btn-outline{border-color:rgba(243,237,228,0.25);color:var(--text-1);}
  .btn-outline:hover{border-color:var(--gold);color:var(--gold);}

  /* SIDE SOCIAL */
  .side-social{
    position:fixed;left:40px;bottom:40px;z-index:50;
    display:flex;flex-direction:column;gap:18px;
  }
  .side-social a{
    width:36px;height:36px;border:1px solid var(--line);border-radius:50%;
    display:flex;align-items:center;justify-content:center;
    color:var(--text-2);transition:all .3s;
  }
  .side-social a:hover{border-color:var(--gold);color:var(--gold);}
  @media(max-width:900px){.side-social{display:none;}}

  /* HERO */
  .hero{
    min-height:100vh;display:flex;align-items:center;position:relative;
    padding-top:90px;
    background:
      radial-gradient(ellipse 60% 50% at 80% 30%, rgba(199,154,95,0.06), transparent),
      var(--bg-0);
  }
  .hero-grid{display:grid;grid-template-columns:1fr 1.15fr;gap:50px;align-items:center;width:100%;}
  .hero-eyebrow{display:flex;align-items:center;gap:8px;margin-bottom:26px;}
  .hero-eyebrow::after{content:'✦';color:var(--gold);font-size:10px;}
  .hero h1{font-size:54px;line-height:1.12;letter-spacing:-0.01em;margin-bottom:24px;color:var(--text-1);}
  .hero p.lead{font-size:15px;line-height:1.8;color:var(--text-2);max-width:380px;margin-bottom:38px;font-weight:300;}
  .hero-ctas{display:flex;gap:14px;margin-bottom:60px;}
  .hero-visual{
    position:relative;border-radius:4px;overflow:hidden;aspect-ratio:4/5;
    background:
      linear-gradient(160deg, #2a221a 0%, #1a140f 60%, #0c0a08 100%);
  }
  .hero-visual::before{
    content:'';position:absolute;inset:0;
    background:
      radial-gradient(circle at 70% 25%, rgba(255,210,150,0.18), transparent 45%),
      repeating-linear-gradient(115deg, rgba(0,0,0,0.06) 0 2px, transparent 2px 5px);
  }
  .hero-visual .ring{
    position:absolute;top:8%;right:10%;width:120px;height:120px;
    border-radius:50%;border:14px solid rgba(255,235,210,0.85);
    filter:blur(1px);box-shadow:0 0 40px rgba(255,210,150,0.4);
  }
  .hero-figure{
    position:absolute;bottom:0;right:6%;width:62%;height:88%;
    background:linear-gradient(200deg,#5a3f2c, #2c1f16 70%);
    border-radius:50% 50% 30% 30% / 60% 60% 20% 20%;
    opacity:0.9;
  }
  .scroll-cue{
    position:absolute;bottom:34px;left:50%;transform:translateX(-50%);
    display:flex;flex-direction:column;align-items:center;gap:8px;
    font-size:10px;letter-spacing:0.2em;text-transform:uppercase;color:var(--text-2);
  }
  .scroll-cue .line{width:1px;height:30px;background:linear-gradient(var(--gold),transparent);animation:pulse 2s infinite;}
  @keyframes pulse{0%,100%{opacity:.3}50%{opacity:1}}

  section{padding:130px 0;position:relative;}
  .sec-head{display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:60px;gap:30px;flex-wrap:wrap;}
  .sec-head h2{font-size:38px;line-height:1.2;}

  /* reveal */
  .reveal{opacity:0;transform:translateY(28px);transition:opacity .8s ease, transform .8s ease;}
  .reveal.visible{opacity:1;transform:translateY(0);}

  /* SERVICES */
  .services-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--line);border:1px solid var(--line);}
  .service-card{
    background:var(--bg-0);padding:46px 36px;transition:background .35s ease;
    position:relative;
  }
  .service-card:hover{background:var(--bg-1);}
  .service-icon{
    width:54px;height:54px;border-radius:50%;background:var(--gold-soft);
    display:flex;align-items:center;justify-content:center;margin-bottom:28px;
    color:var(--gold);font-size:20px;
  }
  .service-card h3{font-size:22px;margin-bottom:10px;font-weight:500;}
  .service-link{font-size:11px;letter-spacing:0.1em;text-transform:uppercase;color:var(--text-2);
    display:inline-flex;align-items:center;gap:6px;margin-top:18px;transition:color .3s,gap .3s;}
  .service-card:hover .service-link{color:var(--gold);gap:10px;}
  @media(max-width:860px){.services-grid{grid-template-columns:1fr 1fr;}}
  @media(max-width:560px){.services-grid{grid-template-columns:1fr;}}

  /* TRANSFORMATIONS */
  .ba-row{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;}
  .ba-card{position:relative;border-radius:4px;overflow:hidden;aspect-ratio:4/5;
    background:linear-gradient(150deg,#3a2c1f,#171210);}
  .ba-tag{position:absolute;top:16px;font-size:10px;letter-spacing:0.15em;color:#fff;text-transform:uppercase;z-index:2;}
  .ba-tag.before{left:16px;} .ba-tag.after{right:16px;}
  .ba-divider{position:absolute;top:0;bottom:0;left:50%;width:1px;background:rgba(255,255,255,0.5);
    display:flex;align-items:center;justify-content:center;}
  .ba-divider span{
    width:26px;height:26px;border-radius:50%;background:#fff;color:#111;
    display:flex;align-items:center;justify-content:center;font-size:11px;
  }
  @media(max-width:860px){.ba-row{grid-template-columns:1fr;}}

  /* ABOUT */
  .about-grid{display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:center;}
  .about-imgs{display:grid;grid-template-columns:1.3fr 1fr;gap:18px;}
  .about-imgs .img-a{aspect-ratio:3/4;background:linear-gradient(160deg,#241c14,#0c0a08);border-radius:4px;align-self:end;}
  .about-imgs .img-b{aspect-ratio:3/4.6;background:linear-gradient(200deg,#4a3526,#1a130d);border-radius:4px;}
  .about-text .name-script{font-family:'Cormorant Garamond';font-style:italic;font-size:22px;color:var(--gold);margin-top:26px;}
  .about-text h2{font-size:36px;margin:14px 0 20px;}
  .about-text p{color:var(--text-2);line-height:1.85;font-size:14.5px;margin-bottom:30px;max-width:430px;}
  .metrics{display:flex;flex-direction:column;gap:1px;background:var(--line);border:1px solid var(--line);border-radius:4px;overflow:hidden;}
  .metric{display:flex;align-items:center;gap:16px;padding:20px 24px;background:var(--bg-1);}
  .metric .num{font-family:'Cormorant Garamond';font-size:28px;color:var(--gold);}
  .metric .label{font-size:10px;letter-spacing:0.08em;text-transform:uppercase;color:var(--text-2);line-height:1.4;}
  @media(max-width:860px){.about-grid{grid-template-columns:1fr;}.about-imgs{order:2;}}

  /* TESTIMONIALS + INSTAGRAM */
  .lower-grid{display:grid;grid-template-columns:1fr 1.3fr;gap:60px;}
  .quote-mark{font-family:'Cormorant Garamond';font-size:54px;color:var(--gold);line-height:1;margin-bottom:10px;}
  .testimonial p{font-size:17px;line-height:1.7;font-family:'Cormorant Garamond';font-weight:400;margin-bottom:18px;}
  .stars{color:var(--gold);font-size:13px;letter-spacing:3px;margin-bottom:10px;}
  .insta-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:10px;margin-top:24px;}
  .insta-grid div{aspect-ratio:1;background:linear-gradient(150deg,#3a2c1f,#161210);border-radius:3px;}
  @media(max-width:860px){.lower-grid{grid-template-columns:1fr;}.insta-grid{grid-template-columns:repeat(3,1fr);}}

  /* CTA BAND */
  .cta-band{
    background:linear-gradient(120deg, #1a1310, #0c0a08 60%);
    padding:80px 0;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:24px;
    border-top:1px solid var(--line);border-bottom:1px solid var(--line);
  }
  .cta-band h2{font-size:32px;}

  /* FOOTER */
  footer{padding:80px 0 30px;}
  .footer-grid{display:grid;grid-template-columns:1.4fr 1fr 1fr 1fr;gap:40px;margin-bottom:60px;}
  .footer-grid p{color:var(--text-2);font-size:13px;line-height:1.7;margin-top:14px;max-width:230px;}
  .footer-col h4{font-size:11px;letter-spacing:0.1em;text-transform:uppercase;color:var(--text-2);margin-bottom:18px;}
  .footer-col a, .footer-col li{display:block;font-size:13.5px;color:var(--text-1);margin-bottom:10px;list-style:none;opacity:0.85;}
  .footer-col a:hover{color:var(--gold);}
  .footer-bottom{display:flex;justify-content:space-between;padding-top:30px;border-top:1px solid var(--line);
    font-size:12px;color:var(--text-2);flex-wrap:wrap;gap:10px;}
  @media(max-width:860px){.footer-grid{grid-template-columns:1fr 1fr;}}

  .wa-float{
    position:fixed;bottom:28px;right:28px;z-index:90;
    width:56px;height:56px;border-radius:50%;background:#25D366;
    display:flex;align-items:center;justify-content:center;
    box-shadow:0 8px 24px rgba(0,0,0,0.4);transition:transform .3s;
  }
  .wa-float:hover{transform:scale(1.08);}
</style>
